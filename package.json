{
  "name": "hono-to-go-lesson",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:ai": "set -o pipefail && biome lint . --reporter=github 2>&1 | { grep '^::' || true; }",
    "lint:fix": "biome lint --write .",
    "lint:unsafe-fix": "biome lint --write --unsafe .",
    "type-check": "tsc --noEmit",
    "type-check:ai": "tsc --noEmit 2>&1",
    "ai-check": "bun run format && bun run lint:ai && bun run type-check:ai",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "bunx wrangler d1 migrations apply hono-to-go-lesson --local",
    "db:migrate:remote": "bunx wrangler d1 migrations apply hono-to-go-lesson --remote"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.4",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.105.0"
  }
}
